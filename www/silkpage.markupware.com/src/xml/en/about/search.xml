<?xml version="1.0" encoding="utf-8"?>
<webpage xmlns:html="http://www.w3.org/1999/xhtml"
	 id="search">
  <config param="rcsdate" value="$Date: 2007-10-30 14:10:18 $"/>
  <head>
    <title>Search</title>
    <summary>Search SilkPage website</summary>
    <keywords>Search</keywords>
  </head>
  <para>
  </para>
  
  <html:form method="get" id="searchForm" title="Google Search Form"
	     action="http://www.google.com/custom">
    <html:fieldset>
      <html:legend>Search SilkPage</html:legend>
      <html:input type="hidden" name="hl" value="en" />
      <html:input type="hidden" name="ie" value="UTF-8"/>
      <html:input type="hidden" name="btnG" value="Google+Search" />
      <html:input type="hidden" name="as_qdr" value="all" />
      <html:input type="hidden" name="as_occt" value="any" />
      <html:input type="hidden" name="as_dt" value="i" />
      <html:input type="hidden" name="cof" value="S:http://www.markupware.com;AH:center;LH:80;L:http://www.markupware.com/img/mw_logo.gif;LW:203;AWFID:baf72b52146229fa;"/>
      <html:input type="hidden" name="domains" value="silkpage.markupware.com"/>
      <html:input type="hidden" id="searchSilkpage" name="sitesearch" 
		  checked="checked" value="silkpage.markupware.com" />
      <html:input type="text" name="q" size="25" maxlength="255" 
		  id="searchText" value="Keyword ..."
		  onfocus="if(this.value=='Keyword ...')this.value='';"
		  onblur="if(this.value=='') this.value='Keyword ...';"/>
      <html:input type="submit" name="sa" id="searchSubmit" value="Search"/>
    </html:fieldset>
  </html:form>
  <para role='searchLinks'>
    <phrase role='sitemap'><olink targetdoc="sitemap"/></phrase> 
  </para>
  <para role='google'>
    <ulink url="http://www.google.com/"><orgname>Google</orgname></ulink>
  </para>
</webpage>
