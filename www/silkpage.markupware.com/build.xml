<?xml version="1.0"?>
<!--
  =======================================================================
  Build instruction of SilkPage Website, Generated by SilkPage.
  To build the site for preview, type in 'ant preview' on the command line
  For Online documentation, http://silkpage.markupware.com/docs/
  =======================================================================
-->

<project name="silkpage.markupware.com" default="preview">
<property file="build.properties"/>
 <!--
       ===================================================================
       preview        		     
       ===================================================================
  -->
<target name="preview"
   description="generates and installs a local copy for preview">
   <ant antfile="${silkpage.home.dir}/src/xml/build/tasks.xml"
     dir="${silkpage.home.dir}" inheritAll="false" target="website">
     <property file="build.properties"/>
   </ant>
</target>
 <!--
       ===================================================================
       publish        		     
       ===================================================================
  -->
<target name="publish" depends="clean-dist, preview"
   description="publishes a copy of your website online">
  <copy toDir="${www.dir}" encoding="${default.encoding}">
    <fileset dir="${dist.dir}"/>
  </copy>
</target>

 <!--
       ===================================================================
       metadata
       ===================================================================
  -->
<target name="metadata"
        description="generates RDF metadata for each XML source">
  <ant antfile="${silkpage.home.dir}/src/xml/build/tasks.xml"
       dir="${silkpage.home.dir}" inheritAll="false" target="websiteMetadata">
     <property file="build.properties"/>
   </ant>
</target>

 <!--
       ===================================================================
       feeds
       ===================================================================
  -->
<target name="feeds" 
        description="generates feeds based on the feed configuration file">
  <exec executable="xsltproc">
    <arg line="--stringparam user.feeds.basedir ${user.feeds.basedir}"/>
    <arg line="${silkpage.home.dir}/src/xsl/common/feeds-config.xsl"/>
    <arg line="${user.feeds.configfile}"/>
  </exec>
</target>

<target name="clean-dist"
        description="deletes everything in ${dist.dir}">
	<echo message="Deleting ${dist.dir}"/>
  <delete dir="${dist.dir} "/>
</target>

</project>
