<?xml version="1.0"?>
<!--
  =======================================================================
  Build instruction of SilkPage, Generated by SilkPage.
  To build the site for preview, type in 'ant preview' on the command line
  For Online documentation, http://silkpage.markupware.com/docs/index.html
  =======================================================================
-->

<project name="silkpage" default="dist">
<property name="silkpage.home.dir" value="${user.dir}/../../projects/silkpage/core"/>
<property file="build.properties"/>
<property name="silkpage.core.version" value="0_3_0"/>
<property name="temp.dir" value="${java.io.tmpdir}"/>
<property name="archive.dir" value="${temp.dir}/archive"/>
<property name="silkpage.core.plus.dist.file" 
  value="silkpage-core-${silkpage.core.version}-plus.zip"/>
<property name="silkpage.core.dist.file" 
  value="silkpage-core-${silkpage.core.version}.zip"/>
<property name="silkpage.docs.file" 
  value="${archive.dir}/silkpage-docs.zip"/>

 <!--
       ===================================================================
       preview        		     
       ===================================================================
  -->
<target name="preview"
   description="generates and installs a local copy for preview">
   <ant antfile="${silkpage.home.dir}/src/xml/build/tasks.xml"
     dir="${silkpage.home.dir}" inheritAll="false" target="installLocal">
     <property file="build.properties"/>
   </ant>
   <copy file="src/php/send.php" tofile="${install.local.dir}/about/send.php"/>
</target>
 <!--
       ===================================================================
       publish        		     
       ===================================================================
  -->
<target name="publish"
   description="publishes a copy of your website online">
   <ant antfile="${silkpage.home.dir}/src/xml/build/tasks.xml"
     dir="${silkpage.home.dir}" inheritAll="false" target="installRemote">
     <property file="build.properties"/>
   </ant>
</target>
 <!--
       ===================================================================
       Copy SilkPage Core files        		     
       ===================================================================
  -->

<target name="copySilkPageCore" 
  depends="copySilkPageCoreDistFile,copySilkPageCorePlusDistFile,copySilkPageUserGuide"/>

<target name="copySilkPageCoreDistFile.init">
   <available file="${archive.dir}/${silkpage.core.dist.file}" type="file"
     property="silkpage.core.dist.file.exists"/>
</target>

<target name="copySilkPageCoreDistFile" 
  depends="copySilkPageCoreDistFile.init" 
  if="silkpage.core.dist.file.exists">
  <copy file="${archive.dir}/${silkpage.core.dist.file}" 
    tofile="${install.local.dir}/downloads/${silkpage.core.dist.file}"/>
   <echo message="${install.local.dir}/downloads/${silkpage.core.dist.file}"/>
</target>

<target name="copySilkPageCorePlusDistFile.init">
   <available file="${archive.dir}/${silkpage.core.plus.dist.file}" type="file"
     property="silkpage.core.plus.dist.file.exists"/>
</target>

<target name="copySilkPageCorePlusDistFile" 
  depends="copySilkPageCorePlusDistFile.init" 
  if="silkpage.core.plus.dist.file.exists">
  <copy file="${archive.dir}/${silkpage.core.plus.dist.file}" 
    tofile="${install.local.dir}/downloads/${silkpage.core.plus.dist.file}"/>
   <echo message="${install.local.dir}/downloads/${silkpage.core.dist.file}"/>
</target>

<target name="copySilkPageUserGuide.init">
   <available file="${silkpage.docs.file}" type="file"
     property="silkpage.docs.file.exists"/>
</target>

<target name="copySilkPageUserGuide" 
  depends="copySilkPageUserGuide.init" if="silkpage.docs.file.exists">
  <unzip src="${silkpage.docs.file}" dest="${install.local.dir}/docs"/>
</target>

<target name="dist" depends="preview,copySilkPageCore"/>

</project>
