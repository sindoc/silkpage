<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE autolayout PUBLIC
  "-//Norman Walsh//DTD Website Autolayout V2.5.0//EN"
  "http://docbook.sourceforge.net/release/website/2.5.0/schema/dtd/autolayout.dtd">
<autolayout>
  <config param="headlink" value="contact"  altval="Contact"/>
  <config param="headlink" value="sitemap"  altval="Site Map"/>
  <config param="title"    value="Lutino"/>
  <copyright role="license">
    <year>2024 - 2026</year>
    <holder role="https://lutino.io/">Lutino</holder>
  </copyright>
  <style src="css/lutino.css" type="text/css"/>

  <toc page="index.xml" id="home" filename="index.html">
    <title>Lutino</title>
    <summary>The Lutino platform</summary>

    <tocentry page="about/index.xml" id="about" dir="about/" filename="index.html">
      <title>About</title>
      <summary>About Lutino</summary>
    </tocentry>

    <tocentry page="docs/index.xml" id="docs" dir="docs/" filename="index.html">
      <title>Documentation</title>
      <summary>Platform documentation</summary>
    </tocentry>
  </toc>

  <notoc page="sitemap.xml" id="sitemap" dir="site/map/" filename="index.html">
    <title>Sitemap</title>
    <summary>Automatically generated sitemap</summary>
  </notoc>
</autolayout>
