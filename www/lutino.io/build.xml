<?xml version="1.0"?>
<!--
  =======================================================================
  Build instructions for lutino.io, generated by SilkPage.
  Type 'ant preview'  to build a local preview.
  Type 'ant publish'  to deploy to ${www.dir}.
  For documentation:  http://silkpage.markupware.com/docs/
  =======================================================================
-->
<project name="lutino.io" default="preview">
  <property file="build.properties"/>

  <!-- preview: generate a local copy for review -->
  <target name="preview"
          description="generates and installs a local copy for preview">
    <ant antfile="${silkpage.home.dir}/src/xml/build/tasks.xml"
         dir="${silkpage.home.dir}" inheritAll="false" target="website">
      <property file="build.properties"/>
    </ant>
  </target>

  <!-- publish: preview then copy to www.dir -->
  <target name="publish" depends="clean-dist, preview"
          description="publishes a copy of your website online">
    <copy toDir="${www.dir}" encoding="${default.encoding}">
      <fileset dir="${dist.dir}"/>
    </copy>
  </target>

  <!-- metadata: generate RDF metadata per XML source -->
  <target name="metadata"
          description="generates RDF metadata for each XML source">
    <ant antfile="${silkpage.home.dir}/src/xml/build/tasks.xml"
         dir="${silkpage.home.dir}" inheritAll="false" target="websiteMetadata">
      <property file="build.properties"/>
    </ant>
  </target>

  <!-- clean-dist -->
  <target name="clean-dist"
          description="deletes everything in ${dist.dir}">
    <echo message="Deleting ${dist.dir}"/>
    <delete dir="${dist.dir}"/>
  </target>
</project>
