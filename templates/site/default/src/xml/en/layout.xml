<?xml version="1.0"?>
<!DOCTYPE layout PUBLIC "-//Norman Walsh//DTD Website Layout V2.4.1//EN"
  "http://docbook.sourceforge.net/release/website/2.4.1/schema/dtd/layout.dtd">
<layout>

<!-- 
 Site Layout of @site.id@ site, generated by SilkPage.
 For online documentation, http://silkpage.markupware.com/docs/index.html
-->
<!--
 ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
 CONFIG: params, copyright, CSS stylesheet
 ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
-->
<config param="footlink" value="sitemap" altval="Sitemap"/>
<config param="navtocwidth" value="220"/>
<config param="title" value="@site.id@"/>

<copyright>
  <year>2004</year>
  <holder role="aboutLicense">@site.id@</holder>
</copyright>

<headlink rel="icon" href="graphics/gif/@site.id@.gif" type="image/gif"/>
<style src="css/@site.id@.css" type="text/css"/>

<!-- 
 ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
 TOC: Table Of Content that appears in the main navigation
 ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
-->

<toc page="index.xml" filename="index.html">

</toc>
<!--
 ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
 NOTOC: files that are generated but not shown in the main navigation
 ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
-->
<notoc page="sitemap.xml" filename="sitemap.html"/>
</layout>
